{
    "name": "@ekino/config",
    "version": "1.0.0",
    "description": "lightweight configuration module powered by yaml",
    "homepage": "https://github.com/ekino/node-config",
    "files": [
        "lib"
    ],
    "type": "module",
    "main": "./lib/esm/index.js",
    "types": "lib/esm/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./lib/esm/index.d.ts",
                "default": "./lib/esm/index.js"
            },
            "require": {
                "types": "./lib/cjs/index.d.ts",
                "default": "./lib/cjs/index.js"
            }
        }
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/ekino/node-config.git"
    },
    "maintainers": [
        {
            "name": "Raphaël Benitte"
        },
        {
            "name": "Nadim El-Boustani"
        }
    ],
    "author": "ekino OSS <oss@ekino.com>",
    "license": "MIT",
    "tags": [
        "config",
        "yaml",
        "lightweight",
        "env",
        "variables environment"
    ],
    "engines": {
        "node": ">=18"
    },
    "dependencies": {
        "js-yaml": "4.x"
    },
    "devDependencies": {
        "@biomejs/biome": "1.9.4",
        "@types/js-yaml": "4.0.9",
        "@types/node": "22.13.5",
        "@vitest/coverage-v8": "3.0.6",
        "commitlint": "19.7.1",
        "conventional-changelog-cli": "5.0.0",
        "typescript": "5.7.3",
        "vitest": "3.0.6"
    },
    "scripts": {
        "build": "pnpm run build:esm && pnpm run build:cjs",
        "build:esm": "tsc -p tsconfig.lib.json --outDir lib/esm",
        "build:cjs": "tsc -p tsconfig.lib.json --module CommonJS --moduleResolution Node --outDir lib/cjs",
        "postbuild:cjs": "echo '{\"type\": \"commonjs\"}' > lib/cjs/package.json",
        "test": "vitest --run",
        "coverage": "vitest run --coverage",
        "version": "echo ${npm_package_version}",
        "lint": "biome check --write",
        "lint-check": "biome check",
        "postinstall": "git config core.hooksPath ./.githooks || true"
    }
}
