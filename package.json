{
    "name": "@ekino/config",
    "version": "1.0.0",
    "description": "lightweight configuration module powered by yaml",
    "homepage": "https://github.com/ekino/node-config",
    "files": [
        "lib"
    ],
    "main": "build/index.js",
    "types": "build/index.d.ts",
    "repository": {
        "type": "git",
        "url": "https://github.com/ekino/node-config.git"
    },
    "maintainers": [
        {
            "name": "Raphaël Benitte"
        },
        {
            "name": "Nadim El-Boustani"
        }
    ],
    "author": "ekino OSS <oss@ekino.com>",
    "license": "MIT",
    "tags": [
        "config",
        "yaml",
        "lightweight",
        "env",
        "variables environment"
    ],
    "engines": {
        "node": ">=18"
    },
    "dependencies": {
        "js-yaml": "4.x"
    },
    "devDependencies": {
        "@biomejs/biome": "1.9.4",
        "@types/jest": "29.5.14",
        "@types/js-yaml": "4.0.9",
        "@types/node": "22.13.5",
        "commitlint": "19.7.1",
        "conventional-changelog-cli": "5.0.0",
        "jest": "29.7.0",
        "nyc": "17.1.0",
        "ts-jest": "29.2.5",
        "typescript": "5.7.3"
    },
    "scripts": {
        "build": "tsc -p tsconfig.lib.json",
        "test": "jest",
        "test-cover": "jest --coverage",
        "coverage": "jest --coverage --coverageReporters=text-lcov | coveralls",
        "version": "echo ${npm_package_version}",
        "lint": "biome check --write",
        "lint-check": "biome check",
        "postinstall": "git config core.hooksPath ./.githooks || true"
    }
}
